# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  Copy this file to .env and fill in your values.
#  docker compose will read .env automatically.
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ─── Bluesky ──────────────────────────────────────────────
# Your bot's handle (the account that will post photos)
BLUESKY_HANDLE=yourbothandle.bsky.social

# Generate an App Password at: bsky.social → Settings → App Passwords
# Use an App Password — NOT your real login password
BLUESKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ─── Chevereto ────────────────────────────────────────────
# Your Chevereto site URL (no trailing slash)
CHEVERETO_BASE_URL=https://yoursite.com

# API key: Chevereto admin panel → Dashboard → API
CHEVERETO_API_KEY=your_api_key_here

# ─── Admins ───────────────────────────────────────────────
# Comma-separated Bluesky handles allowed to send DM commands
ADMIN_HANDLES=you.bsky.social,teammate.bsky.social

# ─── Posting behaviour ────────────────────────────────────
# Photos posted per hour
POSTS_PER_HOUR=4

# Recency bias: 1.0 = uniform random, 3.0 = strong bias toward new uploads
RECENCY_BIAS=3.0

# ─── Dashboard ────────────────────────────────────────────
# Port the web dashboard is exposed on your host machine
DASHBOARD_PORT=3000

# Secret to protect dashboard controls — pick any long random string
DASHBOARD_SECRET=change_me_to_something_long_and_random
