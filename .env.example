# ─── Bluesky ─────────────────────────────────────────────────────────────────
BLUESKY_HANDLE=yourbothandle.bsky.social
BLUESKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ─── Chevereto ───────────────────────────────────────────────────────────────
CHEVERETO_BASE_URL=https://yoursite.com
CHEVERETO_API_KEY=your_api_key_here

# ─── Bot Config ──────────────────────────────────────────────────────────────
# Comma-separated Bluesky handles who can send bot commands via DM
ADMIN_HANDLES=you.bsky.social,teammate.bsky.social

# How many photos to post per hour (default: 4)
POSTS_PER_HOUR=4

# Weight multiplier for recency bias (higher = newer photos favoured more strongly)
# 1.0 = uniform random, 5.0 = strong bias toward recent uploads
RECENCY_BIAS=3.0

# Dashboard port
DASHBOARD_PORT=3000

# Dashboard secret (set a strong random string)
DASHBOARD_SECRET=change_me_to_something_secret
